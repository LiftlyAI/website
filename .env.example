# LLM provider — 'gemini' (default, cheap for testing) or 'anthropic'.
LLM_PROVIDER=gemini

# Gemini API key (used when LLM_PROVIDER=gemini). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic API key (used when LLM_PROVIDER=anthropic). https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Override the default model for the active provider (optional).
# Defaults: gemini -> gemini-2.5-flash, anthropic -> claude-opus-4-7
# COACH_MODEL=

# Supabase Postgres connection string (TRANSACTION pooler, port 6543).
# Supabase → Project Settings → Database → Connection string → Transaction.
DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase Auth. Create a project at https://supabase.com and copy the URL + anon key.
# In your Supabase dashboard: Auth > Providers > Email (enable), Auth > URL Config (set site URL).
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Bar-path CV sidecar (Python/FastAPI). See cv-service/README.md.
CV_SERVICE_URL=http://127.0.0.1:8000

# --- Stripe billing (Pro / Coach plans + usage metering) --------------------
# Secret key: https://dashboard.stripe.com/apikeys (use the TEST key in dev).
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. Local: `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# Prod: Dashboard → Developers → Webhooks → add endpoint /api/stripe/webhook, copy the secret.
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring Price IDs. Create three Prices in the Stripe dashboard (Products):
#   Pro   — $12 / month         -> STRIPE_PRICE_PRO_MONTHLY
#   Pro   — $99 / year          -> STRIPE_PRICE_PRO_ANNUAL
#   Coach — $20 / month, per seat (quantity = active clients) -> STRIPE_PRICE_COACH
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_COACH=price_...
# Public base URL used for Stripe redirect (success/cancel/return) URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
