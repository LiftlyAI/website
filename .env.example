# LLM provider — 'gemini' (default, cheap for testing) or 'anthropic'.
LLM_PROVIDER=gemini

# Gemini API key (used when LLM_PROVIDER=gemini). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic API key (used when LLM_PROVIDER=anthropic). https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Override the default model for the active provider (optional).
# Defaults: gemini -> gemini-2.5-flash, anthropic -> claude-opus-4-7
# COACH_MODEL=

# Path to the SQLite file. Created on first run if missing.
DATABASE_PATH=./data/coach.db

# Session cookie secret. Any long random string in dev; rotate for prod.
SESSION_SECRET=dev-secret-change-me

# Bar-path CV sidecar (Python/FastAPI). See cv-service/README.md.
CV_SERVICE_URL=http://127.0.0.1:8000
